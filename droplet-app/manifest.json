  {
    "manifest_version": 3,
    "name": "Misty",
    "version": "1.0",
    "permissions": ["storage", "notifications", "tabs"],
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://gemini.google.com/*"
    ],
    "action": {
      "default_popup": "app.html",
      "default_icon": "chromeicon.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"],
        "js": ["content.js"]
      }
    ]
  }